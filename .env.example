# Required for Groq-powered models (Llama 3.3 70B, Llama 3.1 8B, Gemma 2 9B)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Required for Claude-powered models (Claude Sonnet)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required for NASA ADS research paper search
# Free key at: https://ui.adsabs.harvard.edu/user/settings/token
ADS_API_KEY=your_ads_api_key_here

# Optional: comma-separated origins allowed to hit the backend (default: localhost:3000)
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
